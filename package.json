{
    "name": "carton-erp",
    "version": "1.0.0",
    "description": "Carton Box Manufacturing ERP",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "build": {
        "appId": "com.sptex.cartonerp",
        "win": {
            "target": "nsis"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true
        },
        "files": [
            "**/*",
            "config.js",
            "!**/*.ts",
            "!*.map",
            "!package-lock.json"
        ]
    },
    "homepage": "https://github.com/sptex/carton-erp",
    "repository": {
        "type": "git",
        "url": "https://github.com/sptex/carton-erp.git"
    },
    "keywords": [],
    "author": "SP TEX",
    "license": "ISC",
    "dependencies": {
        "chart.js": "^4.5.1",
        "mysql2": "^3.9.0"
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^26.4.0"
    }
}